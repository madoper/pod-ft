# pod-ft platform - Environment variables
# Copy to .env and fill values

# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-random-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=podft
POSTGRES_PASSWORD=podft-secret
POSTGRES_DB=podft

# Neo4j (disabled on Sprint 1-2)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=podft-neo4j

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=podft-minio
MINIO_SECRET_KEY=podft-minio-secret
MINIO_BUCKET_RAW=raw-documents
MINIO_BUCKET_PARSED=parsed-documents
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_INTERNAL=internal-documents

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM Provider
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
